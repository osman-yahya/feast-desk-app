{
  "permissions": {
    "allow": [
      "Bash(npm run dev)",
      "Bash(npm run build)",
      "Bash(npm run package)",
      "Bash(npm install*)",
      "Bash(npm install --save*)",
      "Bash(npm install --save-dev*)",
      "Bash(electron-rebuild*)",
      "Bash(ls *)",
      "Bash(find src*)",
      "Bash(cat src/*)",
