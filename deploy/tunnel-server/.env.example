# === Cloudflare Tunnel ===
# Get from: https://one.dash.cloudflare.com/ → Networks → Tunnels → feast-tunnel → Token
CLOUDFLARE_TUNNEL_TOKEN=your-tunnel-token-here

# === Tunnel Server ===
# Public domain for the tunnel (used in access URLs)
TUNNEL_DOMAIN=tunnel.feast.tr

# Max concurrent POS tunnel connections (default: 10000)
MAX_TUNNELS=10000
